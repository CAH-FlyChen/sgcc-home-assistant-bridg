ARG BASE_IMAGE=python:3.12.11-slim-bookworm
FROM ${BASE_IMAGE} AS build

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV SET_CONTAINER_TIMEZONE=true
ENV CONTAINER_TIMEZONE=Asia/Shanghai
ENV TZ=Asia/Shanghai 


ARG TARGETARCH
ARG VERSION
ENV PYTHON_IN_DOCKER='PYTHON_IN_DOCKER'

WORKDIR /app

# Layer 1: basic system deps (small, fast)
RUN apt-get --allow-releaseinfo-change update -o Acquire::Retries=3 \
    && apt-get install -y --no-install-recommends -o Acquire::Retries=3 \
        ca-certificates curl gnupg jq unzip tzdata \
    && rm -rf /var/lib/apt/lists/*

# Layer 2: chromium + xvfb + fonts (large, but cached separately)
RUN apt-get --allow-releaseinfo-change update -o Acquire::Retries=3 \
    && apt-get install -y --no-install-recommends -o Acquire::Retries=3 \
        fonts-noto-cjk chromium chromium-driver xvfb \
    && rm -rf /var/lib/apt/lists/*

# Layer 3: Google Chrome
RUN install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL --retry 3 https://dl.google.com/linux/linux_signing_key.pub \
        | gpg --dearmor -o /etc/apt/keyrings/google-linux.gpg \
    && chmod a+r /etc/apt/keyrings/google-linux.gpg \
    && echo "deb [arch=arm64 signed-by=/etc/apt/keyrings/google-linux.gpg] http://dl.google.com/linux/chrome/deb/ stable main" \
        > /etc/apt/sources.list.d/google-chrome.list \
    && apt-get --allow-releaseinfo-change update -o Acquire::Retries=3 \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        -o Acquire::Retries=3 \
        -o Dpkg::Options::="--force-confdef" \
        -o Dpkg::Options::="--force-confold" \
        google-chrome-stable \
    || (apt-get update -o Acquire::Retries=3 \
        && apt-get install -f -y -o Acquire::Retries=3 \
        && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
            -o Acquire::Retries=3 \
            -o Dpkg::Options::="--force-confdef" \
            google-chrome-stable) \
    && rm -rf /var/lib/apt/lists/*

# Layer 4: matching ChromeDriver + timezone
RUN CHROME_VERSION="$(google-chrome --product-version)" \
    && CHROME_BUILD="${CHROME_VERSION%.*}" \
    && CHROMEDRIVER_URL="https://storage.googleapis.com/chrome-for-testing-public/${CHROME_VERSION}/linux-arm64/chromedriver-linux-arm64.zip" \
    && if ! curl -fsSL --retry 3 --head "$CHROMEDRIVER_URL" >/dev/null 2>&1; then \
         CHROMEDRIVER_VERSION="$(curl -fsSL --retry 3 "https://googlechromelabs.github.io/chrome-for-testing/LATEST_RELEASE_${CHROME_BUILD}")"; \
         CHROMEDRIVER_URL="https://storage.googleapis.com/chrome-for-testing-public/${CHROMEDRIVER_VERSION}/linux-arm64/chromedriver-linux-arm64.zip"; \
       fi \
    && curl -fsSL --retry 3 -o /tmp/chromedriver-linux-arm64.zip "$CHROMEDRIVER_URL" \
    && unzip -q /tmp/chromedriver-linux-arm64.zip -d /tmp \
    && install -m 0755 /tmp/chromedriver-linux-arm64/chromedriver /usr/local/bin/chromedriver \
    && rm -rf /tmp/chromedriver-linux-arm64.zip /tmp/chromedriver-linux-arm64 \
    && /usr/local/bin/chromedriver --version \
    && ln -snf /usr/share/zoneinfo/$TZ /etc/localtime \
    && echo $TZ > /etc/timezone \
    && dpkg-reconfigure --frontend noninteractive tzdata

COPY ./requirements.txt /tmp/requirements.txt

RUN mkdir /data \
    && cd /tmp \
    && python3 -m pip install --upgrade pip \
    && PIP_ROOT_USER_ACTION=ignore pip install \
    --disable-pip-version-check \
    --no-cache-dir \
    -r requirements.txt \
    && rm -rf /tmp/* \
    && pip cache purge \
    && rm -rf /var/lib/apt/lists/* \
    && rm -rf /var/log/*

COPY sgcc_ha_bridge/ /app/sgcc_ha_bridge/
COPY scripts/docker-entrypoint.sh /app/docker-entrypoint.sh
COPY scripts/browser-service-entrypoint.sh /app/browser-service-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh /app/browser-service-entrypoint.sh

ENV LANG=C.UTF-8
ENV VERSION=${VERSION}

CMD ["/app/docker-entrypoint.sh"]
